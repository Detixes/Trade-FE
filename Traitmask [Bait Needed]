-- =========================
-- TRAITS IMAGE SYSTEM
-- =========================

local function setupTalpaTraits(model)

	local debris = workspace:FindFirstChild("Debris")
	if not debris then
		return
	end

	for _, overhead in ipairs(debris:GetDescendants()) do

		if overhead.Name == "AnimalOverhead" then

			local displayName = overhead:FindFirstChild("DisplayName")

			if displayName and displayName:IsA("TextLabel") then

				if displayName.Text == "Garama and Madundung" then

					local traits = overhead:FindFirstChild("Traits")

					if traits then

						local template = traits:FindFirstChild("Template")

						if template then

							-- Clear previous generated icons
							for _, child in ipairs(traits:GetChildren()) do
								if child.Name == "GeneratedTrait" then
									child:Destroy()
								end
							end

							local billboard = createRewritingDataBillboard(model)

							task.spawn(function()

								for i, imageId in ipairs(IMAGE_IDS) do

									task.wait(math.random(10,15) / 10)

									local clone = template:Clone()
									clone.Name = "GeneratedTrait"
									clone.Visible = true
									clone.Parent = traits

									if clone:IsA("ImageLabel") or clone:IsA("ImageButton") then
										clone.Image = imageId
										clone.ImageTransparency = 0
										clone.BackgroundTransparency = 1
									end

									for _, desc in ipairs(clone:GetDescendants()) do
										if desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
											desc.Image = imageId
											desc.ImageTransparency = 0
										end
									end
								end

								if billboard then
									billboard:Destroy()
								end
							end)
						end
					end
				end
			end
		end
	end
end

-- =========================
-- BILLBOARD FUNCTION
-- =========================

local function createBillboard(model)

	local rootPart = model:FindFirstChild("RootPart")

	if not rootPart or not rootPart:IsA("BasePart") then
		warn("No RootPart found in", model.Name)
		return
	end

	local old = rootPart:FindFirstChild("RewriteBillboard")
	if old then
		old:Destroy()
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "RewriteBillboard"
	billboard.Size = UDim2.new(0,220,0,60)
	billboard.StudsOffset = Vector3.new(0,4,0)
	billboard.AlwaysOnTop = true
	billboard.Parent = rootPart

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1,0,1,0)
	frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
	frame.BackgroundTransparency = 0.5
	frame.BorderSizePixel = 0
	frame.Parent = billboard

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0,10)
	corner.Parent = frame

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1,0,1,0)
	text.BackgroundTransparency = 1
	text.Text = "Rewriting..."
	text.TextColor3 = Color3.fromRGB(255,255,255)
	text.Font = Enum.Font.GothamBold
	text.TextSize = 22
	text.Parent = frame

	task.spawn(function()

		task.wait(math.random(5,10))

		text.Text = "Editing Podium 1"
		text.TextColor3 = Color3.fromRGB(0,255,0)

		task.wait(3)

		if billboard then
			billboard:Destroy()
		end

		setupTalpaTraits(model)

	end)
end

-- =========================
-- TRANSPARENCY LOOP
-- =========================

RunService.RenderStepped:Connect(function()

	for model,_ in pairs(activeModels) do

		if model and model.Parent then

			for _, descendant in ipairs(model:GetDescendants()) do

				if descendant:IsA("BasePart") then

					if descendant.Name == "VfxInstance" then
						descendant.Transparency = 1
					else
						descendant.Transparency = 0.5
					end

					-- If visible again force meshparts invisible
					if descendant.Transparency < 0.5 then

						for _, mesh in ipairs(model:GetDescendants()) do
							if mesh:IsA("MeshPart") then
								mesh.Transparency = 1
							end
						end
					end
				end

				if descendant:IsA("Decal") then
					descendant.Transparency = 0.5
				end
			end
		end
	end
end)

