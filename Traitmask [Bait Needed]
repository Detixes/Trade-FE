local function createBillboard(model)
	local rootPart = model:FindFirstChild("RootPart")

	if not rootPart then
		return
	end

	local existing = rootPart:FindFirstChild("RewriteBillboard")
	if existing then
		existing:Destroy()
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "RewriteBillboard"
	billboard.Size = UDim2.new(0,220,0,60)
	billboard.StudsOffset = Vector3.new(0,4,0)
	billboard.AlwaysOnTop = true
	billboard.Parent = rootPart

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1,0,1,0)
	frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
	frame.BackgroundTransparency = 0.5
	frame.Parent = billboard

	Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.Text = "Rewriting..."
	label.TextColor3 = Color3.new(1,1,1)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 22
	label.Parent = frame

	task.spawn(function()
		task.wait(math.random(5,10))

		label.Text = "Awaiting Swap..."
		label.TextColor3 = Color3.fromRGB(0,255,0)
	end)
end

-- =========================
-- TRAITS MODIFIER
-- =========================

local IMAGE_IDS = {
	"rbxassetid://99181785766598",
	"rbxassetid://134655415681926",
	"rbxassetid://121100427764858",
	"rbxassetid://118283346037788"
}

local function modifyTraits()
	local debris = workspace:FindFirstChild("Debris")
	if not debris then
		return
	end

	local template = debris:FindFirstChild("FastOverHeadTemplate")
	if not template then
		return
	end

	local animalOverhead = template:FindFirstChild("AnimalOverhead")
	if not animalOverhead then
		return
	end

	local displayName = animalOverhead:FindFirstChild("DisplayName")
	if not displayName then
		return
	end

	if displayName.Text ~= "Noobini Pizzanini" then
		return
	end

	local traits = animalOverhead:FindFirstChild("Traits")
	if not traits then
		return
	end

	local templateClone = traits:FindFirstChild("Template")
	if not templateClone then
		return
	end

	if traits:FindFirstChild("InjectedTrait1") then
		return
	end

	for i, imageId in ipairs(IMAGE_IDS) do
		local clone = templateClone:Clone()
		clone.Name = "InjectedTrait" .. i
		clone.Visible = true
		clone.Parent = traits

		-- Find image objects
		for _, obj in ipairs(clone:GetDescendants()) do
			if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
				obj.Image = imageId
				obj.ImageTransparency = 0
				obj.BackgroundTransparency = 1
			end
		end
	end
end

-- =========================
-- TRANSPARENCY LOOP
-- =========================

RunService.RenderStepped:Connect(function()

	modifyTraits()

	for model,_ in pairs(activeModels) do
		if model and model.Parent then

			for _, descendant in ipairs(model:GetDescendants()) do

				-- KEEP VFX INVISIBLE
				if descendant.Name == "VfxInstance" and descendant:IsA("BasePart") then
					descendant.Transparency = 1
				end

				-- FORCE MESH PARTS INVISIBLE IF THEY TURN VISIBLE
				if descendant:IsA("MeshPart") then
					if descendant.Transparency < 1 then
						descendant.Transparency = 1
					end
				end

				-- OTHER PARTS
				if descendant:IsA("BasePart") and descendant.Name ~= "VfxInstance" then
					if not descendant:IsA("MeshPart") then
						descendant.Transparency = 0.5
					end
				end

				-- DECALS
				if descendant:IsA("Decal") then
					descendant.Transparency = 0.5
				end
			end
		end
	end
end)

